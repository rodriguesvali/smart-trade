{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend: FastAPI",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/backend/.venv/bin/python",
      "module": "uvicorn",
      "args": [
        "app.main:app",
        "--host",
        "0.0.0.0",
        "--port",
        "8000",
        "--reload"
      ],
      "cwd": "${workspaceFolder}/backend",
      "envFile": "${workspaceFolder}/backend/.env",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/backend",
        "SMART_TRADE_ENVIRONMENT": "development"
      },
      "justMyCode": true
    },
    {
      "name": "Backend: FastAPI (terminal)",
      "type": "node-terminal",
      "request": "launch",
      "command": ".venv/bin/python -m uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload",
      "cwd": "${workspaceFolder}/backend"
    },
    {
      "name": "Backend: Training Worker",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/backend/.venv/bin/python",
      "module": "app.workers.training_worker",
      "cwd": "${workspaceFolder}/backend",
      "envFile": "${workspaceFolder}/backend/.env",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/backend",
        "SMART_TRADE_ENVIRONMENT": "development"
      },
      "justMyCode": true
    },
    {
      "name": "Backend: Training Worker (terminal)",
      "type": "node-terminal",
      "request": "launch",
      "command": ".venv/bin/python -m app.workers.training_worker",
      "cwd": "${workspaceFolder}/backend"
    },
    {
      "name": "Backend: Tests",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/backend/.venv/bin/python",
      "module": "pytest",
      "args": [
        "-q",
        "tests"
      ],
      "cwd": "${workspaceFolder}/backend",
      "envFile": "${workspaceFolder}/backend/.env",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/backend",
        "SMART_TRADE_DATABASE_URL": "sqlite:///./var/test_smart_trade.db",
        "SMART_TRADE_ARTIFACT_DIR": "./var/test-models",
        "GLOBAL_RANDOM_SEED": "42"
      },
      "justMyCode": true
    }
  ],
  "compounds": [
    {
      "name": "Backend: API + Swagger",
      "configurations": [
        "Backend: FastAPI"
      ],
      "stopAll": true
    },
    {
      "name": "Backend: API + Worker",
      "configurations": [
        "Backend: FastAPI",
        "Backend: Training Worker"
      ],
      "stopAll": true
    }
  ]
}
