{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend: FastAPI",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/backend/.venv/bin/python",
      "module": "uvicorn",
      "args": [
        "smart_trade_api.main:app",
        "--host",
        "0.0.0.0",
        "--port",
        "8000",
        "--reload"
      ],
      "cwd": "${workspaceFolder}/backend",
      "envFile": "${workspaceFolder}/backend/.env",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/backend",
        "SMART_TRADE_ENVIRONMENT": "development"
      },
      "justMyCode": true
    },
    {
      "name": "Backend: FastAPI (terminal)",
      "type": "node-terminal",
      "request": "launch",
      "command": ".venv/bin/python -m uvicorn smart_trade_api.main:app --host 0.0.0.0 --port 8000 --reload",
      "cwd": "${workspaceFolder}/backend"
    },
    {
      "name": "Backend: Training Worker",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/backend/.venv/bin/python",
      "module": "smart_trade_training_worker.main",
      "cwd": "${workspaceFolder}/backend",
      "envFile": "${workspaceFolder}/backend/.env",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/backend",
        "SMART_TRADE_ENVIRONMENT": "development"
      },
      "justMyCode": true
    },
    {
      "name": "Backend: Training Worker (terminal)",
      "type": "node-terminal",
      "request": "launch",
      "command": ".venv/bin/python -m smart_trade_training_worker.main",
      "cwd": "${workspaceFolder}/backend"
    },
    {
      "name": "Backend: Tests",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/backend/.venv/bin/python",
      "module": "pytest",
      "args": [
        "-q",
        "tests"
      ],
      "cwd": "${workspaceFolder}/backend",
      "envFile": "${workspaceFolder}/backend/.env",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/backend",
        "SMART_TRADE_DATABASE_URL": "sqlite:///./var/test_smart_trade.db",
        "SMART_TRADE_ARTIFACT_DIR": "./var/test-models",
        "GLOBAL_RANDOM_SEED": "42"
      },
      "justMyCode": true
    },
    {
      "name": "Frontend: Angular",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm start -- --host 0.0.0.0",
      "cwd": "${workspaceFolder}/frontend"
    },
    {
      "name": "Frontend: Browser",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "http://localhost:4200",
      "webRoot": "${workspaceFolder}/frontend",
      "preLaunchTask": "Frontend: start",
      "sourceMaps": true
    },
    {
      "name": "Backend: Swagger Browser",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "http://localhost:8000/docs",
      "webRoot": "${workspaceFolder}/backend",
      "sourceMaps": false
    }
  ],
  "compounds": [
    {
      "name": "Backend: API + Swagger",
      "configurations": [
        "Backend: FastAPI",
        "Backend: Swagger Browser"
      ],
      "stopAll": true
    },
    {
      "name": "Backend: API + Worker",
      "configurations": [
        "Backend: FastAPI",
        "Backend: Training Worker"
      ],
      "stopAll": true
    },
    {
      "name": "Full Stack: API + Worker + Frontend",
      "configurations": [
        "Backend: FastAPI",
        "Backend: Training Worker",
        "Frontend: Angular"
      ],
      "stopAll": true
    },
    {
      "name": "Full Stack: API + Worker + Frontend + Browser",
      "configurations": [
        "Backend: FastAPI",
        "Backend: Training Worker",
        "Frontend: Browser"
      ],
      "stopAll": true
    }
  ]
}
