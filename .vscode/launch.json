{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend: FastAPI (uv)",
      "type": "node-terminal",
      "request": "launch",
      "command": "cd backend && uv run --group training --group exchange uvicorn smart_trade_backend.main:app --host 0.0.0.0 --port 8000 --reload",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Frontend: Angular",
      "type": "node-terminal",
      "request": "launch",
      "command": "cd frontend && npm start",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Frontend: Angular (Chrome)",
      "type": "chrome",
      "request": "launch",
      "preLaunchTask": "Frontend: start",
      "url": "http://localhost:4200/",
      "webRoot": "${workspaceFolder}/frontend"
    },
    {
      "name": "Backend: FastAPI Debug",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "smart_trade_backend.main:app",
        "--host",
        "0.0.0.0",
        "--port",
        "8000",
        "--reload"
      ],
      "cwd": "${workspaceFolder}/backend",
      "envFile": "${workspaceFolder}/backend/.env",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/backend/src"
      },
      "justMyCode": true
    }
  ],
  "compounds": [
    {
      "name": "Full Stack: Backend + Frontend",
      "configurations": [
        "Backend: FastAPI (uv)",
        "Frontend: Angular"
      ],
      "stopAll": true
    }
  ]
}
