{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend: start",
      "type": "shell",
      "command": "/usr/local/bin/python -m uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload",
      "options": {
        "cwd": "${workspaceFolder}/backend",
        "env": {
          "PYTHONPATH": "${workspaceFolder}/backend",
          "SMART_TRADE_ENVIRONMENT": "development",
          "SMART_TRADE_DATABASE_URL": "sqlite:///./var/smart_trade.db",
          "SMART_TRADE_ARTIFACT_DIR": "./var/models",
          "GLOBAL_RANDOM_SEED": "42"
        }
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "python",
        "pattern": {
          "regexp": "^(.*)$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Uvicorn running on|Started reloader process",
          "endsPattern": "Application startup complete|Uvicorn running on"
        }
      }
    },
    {
      "label": "Backend: worker",
      "type": "shell",
      "command": ".venv/bin/python -m app.workers.training_worker",
      "options": {
        "cwd": "${workspaceFolder}/backend",
        "env": {
          "PYTHONPATH": "${workspaceFolder}/backend",
          "SMART_TRADE_ENVIRONMENT": "development"
        }
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Backend: test",
      "type": "shell",
      "command": "/usr/local/bin/python -m pytest -q tests",
      "options": {
        "cwd": "${workspaceFolder}/backend",
        "env": {
          "PYTHONPATH": "${workspaceFolder}/backend",
          "SMART_TRADE_DATABASE_URL": "sqlite:///./var/test_smart_trade.db",
          "SMART_TRADE_ARTIFACT_DIR": "./var/test-models",
          "GLOBAL_RANDOM_SEED": "42"
        }
      },
      "problemMatcher": []
    }
  ]
}
