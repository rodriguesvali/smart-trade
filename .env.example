SMART_TRADE_ENVIRONMENT=development
SMART_TRADE_DATABASE_URL=mysql+pymysql://smart_trade:smart_trade@mysql:3306/smart_trade
SMART_TRADE_RUN_MIGRATIONS_ON_STARTUP=true

SMART_TRADE_EXCHANGE=bybit
SMART_TRADE_SYMBOL=BTC/USDT
SMART_TRADE_TIMEFRAME=M1
SMART_TRADE_INITIAL_CAPITAL_USD=1000
SMART_TRADE_MODE=paper

BYBIT_API_KEY=
BYBIT_API_SECRET=

SMART_TRADE_MODEL_ARTIFACT_DIR=/workspaces/smart-trade/var/models
SMART_TRADE_LOG_DIR=/workspaces/smart-trade/var/logs
