SMART_TRADE_ENVIRONMENT=development
SMART_TRADE_DATABASE_URL=sqlite:///./var/smart_trade.db
SMART_TRADE_ARTIFACT_DIR=./var/models
GLOBAL_RANDOM_SEED=42

# Product default: real market candles via CCXT public APIs.
SMART_TRADE_DATA_MODE=real
SMART_TRADE_EXCHANGE_ID=binance
SMART_TRADE_DEFAULT_SYMBOL=BTC/USDT
SMART_TRADE_DEFAULT_TIMEFRAME=M5
SMART_TRADE_TRAINING_ROWS=900

# When true, training fails unless Open Interest, Long/Short Ratio, and Taker Buy/Sell Ratio are available.
SMART_TRADE_SENTIMENT_REQUIRED=true

SMART_TRADE_TARGET_N=15
SMART_TRADE_TARGET_TAKE_PROFIT_PCT=0.0015
SMART_TRADE_TARGET_STOP_LOSS_PCT=0.0010
SMART_TRADE_VALIDATION_RATIO=0.2
SMART_TRADE_HOLDOUT_RATIO=0.2
SMART_TRADE_PROBABILITY_THRESHOLD=0.55
