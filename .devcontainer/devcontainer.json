{
  "name": "Smart Trade Dev",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/smart-trade",
  "containerUser": "root",
  "remoteUser": "root",
  "shutdownAction": "stopCompose",
  "postCreateCommand": ".devcontainer/post-create.sh",
  "forwardPorts": [4200, 8000, 3306],
  "portsAttributes": {
    "4200": {
      "label": "Angular dev server",
      "onAutoForward": "notify"
    },
    "8000": {
      "label": "Python API",
      "onAutoForward": "notify"
    },
    "3306": {
      "label": "MySQL",
      "onAutoForward": "silent"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "ms-azuretools.vscode-docker",
        "Angular.ng-template",
        "esbenp.prettier-vscode",
        "openai.chatgpt",
        "odriguesvali.git-revision-graph"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.terminal.activateEnvironment": false,
        "editor.formatOnSave": true,
        "js/ts.tsdk.path": "frontend/node_modules/typescript/lib"
      }
    }
  },
  "remoteEnv": {
    "PATH": "/usr/local/py-utils/bin:${containerEnv:PATH}"
  }
}
